{
  "@context": {
    "prov": "http://www.w3.org/ns/prov#",
    "models": "{{ model_base_iri }}"
  },
  "@graph": [
    {
      "@id": "models:{{ env_id }}",
      "@type": "prov:Collection",
      "prov:hadMember": [
        "models:{{ env_id }}/json-ld/",
        {% for source_file in source_files -%}
        "models:{{ env_id }}/{{ source_file }}"{% if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    },
    {% for source_file in source_files -%}
    {
      "@id": "models:{{ source_file }}",
      "@type": "prov:Entity"
    },
    {%- endfor %}
    {
      "@id": "models:{{ env_id }}/json-ld/",
      "@type": "prov:Collection",
      "prov:hadMember": [
        {% for gen_file in generated_files -%}
          "models:{{ env_id }}/json-ld/{{ gen_file }}"{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      "prov:wasDerivedFrom": [
        {% for source_file in source_files -%}
        "models:{{ env_id }}/{{ source_file }}"{% if not loop.last %},{% endif %}
        {%- endfor %}
      ],
      "prov:generatedAtTime": "{{ gen_time }}"
    },
    {% for gen_file in generated_files -%}
    {
      "@id": "models:{{ env_id }}/json-ld/{{ gen_file }}",
      "@type": "prov:Entity"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}