{
  "@context": {
    "prov": "http://www.w3.org/ns/prov#",
    "smm": "https://secorolab.github.io/metamodels/scenario#",
    "secoro": "https://secorolab.github.io/models/"
  },
  "@graph": [
    {
      "@id": "secoro:{{ env_id }}",
      "@type": "prov:Collection",
      "prov:hadMember": [
        {% for gen_file in generated_files -%}
          "secoro:{{ env_id }}/{{ gen_file }}",
        {% endfor -%}
        {% for source_file in source_files -%}
        "secoro:{{ env_id }}/{{ source_file }}"{% if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    },
    {% for source_file in source_files -%}
    {
      "@id": "secoro:{{ env_id }}/{{ source_file }}",
      "@type": "prov:Entity"
    },
    {%- endfor %}
    {% for gen_file in generated_files -%}
    {
      "@id": "secoro:{{ env_id }}/{{ gen_file }}",
      "@type": ["prov:Entity", "smm:{{ artefact_type }}"],
      "prov:wasDerivedFrom": [
        {% for source_file in source_files -%}
        "secoro:{{ env_id }}/{{ source_file }}"{% if not loop.last %},{% endif %}
        {%- endfor %}
      ],
      "prov:generatedAtTime": "{{ gen_time }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}