[
  {
    "@id":  "{{ parent_id }}",
    "shape": "{{ solid_id }}-polygon"
  },
{
  "@id": "{{ solid_id }}-polygon",
  "@type": "Polygon",
  "points": [
    {%- for p in coords[:4] -%}
    {% set point_id = solid_id ~ "-point-" ~ loop.index  %}
    "{{ point_id }}"{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
},
{%- for p in coords[:4] -%}
{% set point_id = solid_id ~ "-point-" ~ loop.index  %}
{
"@id": "{{ point_id }}",
"@type": [ "3D", "Euclidean", "Point" ]
},
{
"@id": "position-{{ point_id }}",
"@type": "Position",
"of": "{{ point_id }}",
"with-respect-to": "{{ solid_id }}-origin",
"quantity-kind": "Length"
},
{
"@id": "position-coord-{{ point_id }}-wrt-{{ element_id }}-origin",
"@type": [ "PositionReference", "PositionCoordinate", "VectorXYZ" ],
"of-position": "position-{{ point_id }}",
"as-seen-by": "{{ solid_id }}-frame",
"unit": "{{ length_unit }}",
"coordinates": {{ p }}
}{% if not loop.last %},{% endif %}
{% endfor %}
]
