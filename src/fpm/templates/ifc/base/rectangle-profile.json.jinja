[
  {
    "@id":  "{{ parent_id }}",
    "shape": "{{ solid_id }}-polygon",
    "3d-shape": "{{ solid_id }}"
  },
{
  "@id": "{{ solid_id }}-polygon",
  "@type": "Polygon",
  "points": [
    {% for i in range(1,5) -%}
    "{{ solid_id }}-point-{{ i }}"{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
},
{
"@id": "{{ solid_id }}",
"@type": "Polyhedron",
"points": [
{% for i in range(1,9) -%}
"{{ solid_id }}-point-{{ i }}"{% if not loop.last %},{% endif %}
{%- endfor %}
],
"faces": []
},
  {% for p in coords %}
  {% set point_id = solid_id ~ "-point-" ~ loop.index  %}
  {
    "@id": "{{ point_id }}",
    "@type": [ "3D", "Euclidean", "Point" ]
  },
  {
    "@id": "position-{{ point_id }}",
    "@type": "Position",
    "of": "{{ point_id }}",
    "with-respect-to": "{{ solid_id }}-origin",
    "quantity-kind": "Length"
  },
  {
    "@id": "position-coord-{{ point_id }}-wrt-{{ solid_id }}-origin",
    "@type": [ "PositionReference", "PositionCoordinate", "VectorXYZ" ],
    "of-position": "position-{{ point_id }}",
    "as-seen-by": "{{ solid_id }}-frame",
    "unit": "{{ length_unit }}",
    "coordinates": {{ p }}

  }{% if not loop.last %},{% endif %}
  {% endfor %}
]
